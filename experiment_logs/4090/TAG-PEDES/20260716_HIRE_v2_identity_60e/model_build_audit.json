{
  "model_class": "HIREV2Identity",
  "num_classes": 4840,
  "sampler_class": "RandomSampler",
  "batch_images_shape": [
    64,
    3,
    384,
    128
  ],
  "batch_caption_ids_shape": [
    64,
    77
  ],
  "batch_support_images_shape": [
    64,
    3,
    3,
    384,
    128
  ],
  "batch_support_mask_shape": [
    64,
    3
  ],
  "batch_valid_group_ratio": 0.96875,
  "optimizer_groups": {
    "base_model.visual.conv1.weight": {
      "lr": 1e-05,
      "weight_decay": 4e-05

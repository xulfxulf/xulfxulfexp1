    "image_tse.mlp.fc1.weight": {
      "lr": 5e-05,
      "weight_decay": 4e-05
    },
    "image_fusion.local_adapter.weight": {
      "lr": 5e-05,
      "weight_decay": 4e-05
    },
    "identity_mean.proj.weight": {
      "lr": 5e-05,
      "weight_decay": 4e-05
    },
    "image_uncertainty.proj.weight": {
      "lr": 5e-05,
      "weight_decay": 4e-05
    },
    "image_uncertainty.proj.bias": {
      "lr": 0.0001,
      "weight_decay": 0.0
    },
    "identity_gate.logit": {
      "lr": 5e-05,
      "weight_decay": 4e-05
    }
  },
  "args": {
    "dataset_name": "TAG-PEDES",
    "pretrain_choice": "ViT-B/16",
    "batch_size": 64,
    "seed": 1,
    "num_epoch": 60,
    "sampler": "random",
    "img_aug": false,
